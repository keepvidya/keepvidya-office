{
  "name": "keepvidya-office",
  "version": "0.1.0",
  "private": true,
  "description": "Keepvidya Office — a private, local-first, AI-native office suite (Writer / Sheets / Slides). The LLM drafts validated intent; deterministic engines build the real file. Built to compete with MS Office on ownership and privacy.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "boundary": "depcruise src",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "coverage": "vitest run --coverage",
    "e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitest/coverage-v8": "^2.1.2",
    "dependency-cruiser": "^16.4.0",
    "eslint": "^9.12.0",
    "fake-indexeddb": "^6.0.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "vite": "^5.4.0",
    "vitest": "^2.1.2"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "docx": "^9.7.1",
    "exceljs": "^4.4.0",
    "pptxgenjs": "^4.0.1"
  }
}
